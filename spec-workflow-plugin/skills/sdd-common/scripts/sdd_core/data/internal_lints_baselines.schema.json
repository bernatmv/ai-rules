{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "internal_lints_baselines.schema.json",
  "title": "Internal-Lints Baseline Manifest",
  "description": "Set-membership baselines keyed by rule id. Sorted on write by (file, line, reason).",
  "type": "object",
  "required": ["schemaVersion", "rules"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "_doc": {"type": "string"},
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["entries"],
        "additionalProperties": false,
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file", "line", "reason"],
              "additionalProperties": false,
              "properties": {
                "file": {"type": "string", "minLength": 1},
                "line": {"type": "integer", "minimum": 0},
                "reason": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
