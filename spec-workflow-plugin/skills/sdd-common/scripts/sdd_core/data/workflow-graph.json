  "advisories": {
    "_doc": "Advisory placement metadata. Each entry declares where the advisory fires, which workflow phase naturally refreshes the underlying state, and the severity for the phase-mismatch case. The advisory_phase_placement lint reads this block to enforce that fires_at_phase < refresh_handled_by_phase implies no next_action_command and the declared severity.",
    "review_quality_stale": {
      "fires_at_phase": "pre-flight",
      "refresh_handled_by_phase": "post-review",
      "severity_when_phase_mismatch": "info"
    },
    "unstaged_spec_edits_without_approval": {
      "fires_at_phase": "pre-flight",
      "refresh_handled_by_phase": "update-launch",
      "severity_when_phase_mismatch": "warn"
    }
  }
