{
  "$schema": "./internal_lints_baselines.schema.json",
  "schemaVersion": "1.0.0",
  "_doc": "Canonical workflow graph. One declarative source for what phases each workflow runs, what context each phase needs, what gate prompt fires, what handoffs the success envelope carries, and how transitions advance/reject. Strict: every value is a literal; preconditions/validations resolve to registered Validator functions in sdd_core/validators; gate_prompt_id and handoff_ids are foreign keys into prompt-registry.json and handoff-registry.json.",
  "workflows": {
    "sdd-create-spec": {
      "version": "1.0.0",
      "context_needs": ["target", "workspace"],
      "phases": [
        {
          "id": "requirements",
          "produces": ["requirements.md"],
          "preconditions": [],
          "validations": [],
          "gate_prompt_id": "",
          "review_artifacts": ["requirements"],
          "handoff_ids": [],
          "transitions": {
            "approve": "ui-design",
            "reject": "requirements",
            "back": null
          }
        },
        {
          "id": "ui-design",
          "produces": ["ui-design.md"],
          "preconditions": [],
          "validations": [],
          "gate_prompt_id": "",
          "review_artifacts": ["ui-design"],
          "handoff_ids": [],
          "transitions": {
            "approve": "design",
            "reject": "ui-design",
            "back": "requirements"
          }
        },
        {
          "id": "design",
          "produces": ["design.md"],
          "preconditions": [],
          "validations": [],
          "gate_prompt_id": "",
          "review_artifacts": ["design"],
          "handoff_ids": [],
          "transitions": {
            "approve": "tasks",
            "reject": "design",
            "back": "ui-design"
          }
        },
        {
          "id": "tasks",
          "produces": ["tasks.md"],
          "preconditions": [],
          "validations": [],
          "gate_prompt_id": "",
          "review_artifacts": ["tasks"],
          "handoff_ids": [],
          "transitions": {
            "approve": null,
            "reject": "tasks",
            "back": "design"
          }
        }
      ]
    },
    "sdd-workspace-create-spec": {
      "extends": "sdd-create-spec",
      "version": "1.0.0",
      "context_needs": ["target", "workspace", "repo_id"],
      "phase_overrides": {
        "requirements": {
          "gate_prompt_id": "workspace-batch-review-phase",
          "handoff_ids": [
            "workspace/check-spec-shape.py",
            "workspace/phase-approve.py"
          ]
        },
        "ui-design": {
          "gate_prompt_id": "workspace-batch-review-phase",
          "handoff_ids": [
            "workspace/check-spec-shape.py",
            "workspace/phase-approve.py"
          ]
        },
        "design": {
          "gate_prompt_id": "workspace-batch-review-phase",
          "handoff_ids": [
            "workspace/check-spec-shape.py",
            "workspace/phase-approve.py"
          ]
        },
        "tasks": {
          "gate_prompt_id": "workspace-batch-review-phase",
          "handoff_ids": [
            "workspace/check-spec-shape.py",
            "workspace/phase-approve.py"
          ]
        }
      },
      "phases_appended": []
    },
