#!/usr/bin/env python3
"""SDD script runner shim — IDE-independent entry point."""
import sys
sys.dont_write_bytecode = True

import os

_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
for _ide in (".cursor", ".claude"):
    _scripts = os.path.join(_root, _ide, "skills", "sdd-common", "scripts")
    if os.path.isdir(_scripts):
        break
else:
    print(
        '{"status":"error","error":"No SDD skills directory found",'
        '"hint":"Expected .cursor/skills/ or .claude/skills/","context":""}',
        file=sys.stderr,
    )
    sys.exit(1)

sys.path.insert(0, _scripts)
from sdd_core.__main__ import main

main()
