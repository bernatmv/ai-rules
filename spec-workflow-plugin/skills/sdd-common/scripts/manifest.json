  "commands": [
    {
      "operation": "Initialize workspace",
      "command": "`workspace/init.py [--workspace PATH]`"
    },
    {
      "operation": "Pre-flight all repos in workspace",
      "command": "`workspace/preflight-all.py [--target NAME] [--auto-fix]`"
    },
    {
      "operation": "Request approval",
      "command": "`approval/request.py --title \"...\" --file-paths \"a.md\" --type document --category spec --target-name \"...\"`"
    },
    {
      "operation": "Check approval status",
      "command": "`approval/check-status.py --approval-id \"...\" \\| --category-name \"...\"`"
    },
    {
      "operation": "Delete approval",
      "command": "`approval/delete.py --approval-id \"...\"`"
    },
    {
      "operation": "Check spec status",
      "command": "`spec/check-status.py --target \"...\" \\| --all \\| --type steering`"
    },
    {
      "operation": "Log implementation",
      "command": "`util/log-implementation.py --spec-name \"...\" --task-id \"...\" --summary \"...\" --files-modified JSON --files-created JSON --statistics JSON --artifacts JSON`"
    },
    {
      "operation": "Create snapshot",
      "command": "`spec/create-snapshot.py --file-path \"...\" --approval-id \"...\" --trigger initial\\|revision_requested\\|approved\\|manual`"
    },
    {
      "operation": "Compare snapshots",
      "command": "`spec/create-snapshot.py --compare --category-name \"...\" --file-name \"...\" --snapshot-a N --snapshot-b N`"
    },
    {
      "operation": "Archive/unarchive spec",
      "command": "`spec/archive.py --target \"...\" --action archive\\|unarchive\\|status`"
    },
    {
      "operation": "Clean up old approvals",
      "command": "`approval/cleanup.py [--max-age-days N] [--dry-run]`"
    },
    {
      "operation": "Detect spec type",
      "command": "`spec/detect-type.py <spec-name>` (exit 0=bug-fix, 1=standard, 2=usage error)"
    },
    {
      "operation": "Parse task progress",
      "command": "`util/parse-task-progress.py --tasks-file \"...\"`"
    },
    {
      "operation": "Lint tasks format",
      "command": "`spec/lint-tasks.py --target <spec-name>` (deterministic per-doc check; exit 0 with `outcome=\"partial\"` on findings)"
    },
    {
      "operation": "Lint requirements antipatterns",
      "command": "`spec/lint-requirements.py --target <spec-name> [--mode standard|bug-fix]`"
    },
    {
      "operation": "Lint design antipatterns",
      "command": "`spec/lint-design.py --target <spec-name>`"
    },
    {
      "operation": "Check requirements traceability",
      "command": "`spec/check-traceability.py --target <spec-name>`"
    },
    {
      "operation": "Check workspace spec shape",
      "command": "`workspace/check-spec-shape.py --target <feature>/<repo-id> [--target-repo PATH] [--doc requirements|design|tasks]`"
    },
    {
      "operation": "Bootstrap workspace feature (manifest + tracker)",
      "command": "`workspace/init-feature.py --workspace PATH --target <feature> --repo coordinator:<path>(absolute):<feature> --repo target:<path>(absolute):<sub-spec> [--idempotent | --force]`"
    },
    {
      "operation": "Retroactive review for missing artifacts",
      "command": "`workspace/retroactive-review.py --workspace PATH --target <feature> [--phase requirements|design|tasks] [--phase-repo-id ID] [--dry-run]`"
    },
    {
      "operation": "Approve workspace phase",
      "command": "`workspace/phase-approve.py --target <feature> --doc requirements|design|tasks [--dry-run]`"
    },
    {
      "operation": "List pending approvals",
      "command": "`approval/list-pending.py [--category spec\\|steering] [--target NAME]`"
    },
    {
      "operation": "Update approval status",
      "command": "`approval/update-status.py <file> <action: approve\\|reject\\|needs_revision> \"<response>\" [--actor <actor>]`"
    },
    {
      "operation": "Detect spec context",
      "command": "`spec/detect-context.py <spec-name> [--workspace PATH]` (exit 0=workspace, 1=standalone, 2=usage error)"
    },
    {
      "operation": "Check re-review needed",
      "command": "`review/check-re-review.py --doc \"...\" --spec-name \"...\" --category spec\\|steering\\|discovery [--workspace PATH]`"
    },
    {
      "operation": "Create discovery project",
      "command": "`discovery/init-project.py --name \"...\"`"
    },
    {
      "operation": "Update discovery manifest",
      "command": "`discovery/update-manifest.py --name \"...\" <subcommand> [args...]`"
    },
    {
      "operation": "Update workspace manifest",
      "command": "`workspace/update-manifest.py --target <feature> <subcommand> [args...]`"
    },
    {
      "operation": "Validate discovery manifest",
      "command": "`discovery/validate-manifest.py --name \"...\"`"
    },
    {
      "operation": "Resolve template",
      "command": "`util/resolve-template.py --type TYPE [--spec-name NAME] [--content] [--workspace PATH]`"
    },
    {
      "operation": "Validate PRD structure",
      "command": "`prd/validate-prd.py <prd.md>` (exit 0=pass, 1=issues, 2=usage error)"
    },
    {
      "operation": "Validate PRD readiness gate",
      "command": "`prd/validate-readiness.py --target \"...\" --gate pre-requirements\\|pre-generation [--session-file]`"
    },
    {
      "operation": "Write PRD session state",
      "command": "`prd/write-session-state.py --target \"...\" --step N --data '{...}'`"
    },
    {
      "operation": "Delete PRD session state",
      "command": "`prd/write-session-state.py --target \"...\" --delete`"
    },
    {
      "operation": "Check template compliance",
      "command": "`review/check-template-compliance.py <template_file> <document_file>`"
    },
    {
      "operation": "Count effective lines",
      "command": "`review/count-effective-lines.py --file FILE [--file FILE ...]` \u2014 single file returns `{ \"count\": N, \"file\": \"...\" }`; multiple files returns `{ \"results\": [{ \"file\": \"...\", \"count\": N }, ...] }`"
    },
    {
      "operation": "Prepare review pipeline",
      "command": "`review/pipeline-tick.py --phase launch\\|check-revalidation\\|post-fix\\|pre-approval\\|ack-calls [args...] [--parent-todo STEP_ID] [--gate-id STEP_ID]` \u2014 always exits 0; **output contract:** every phase returns `next_action_command` \u2014 a fully-formed command for the next step; always execute `next_action_command` rather than constructing commands manually; substitute `{placeholder}` values from runtime context (e.g. `{issue_count}` from sub-agent output); launch output also returns `re_review_commands` (array, one per doc), `progress_checklist`, and `score_normalization`; when `--parent-todo` is provided, phases include `todo_write_payload` \u2014 pass directly to TodoWrite; after executing TodoWrite, run `--phase ack-calls` to clear pending state; `post-review` output carries `phase_commands.post_fix_user_choices` (allowed) and `phase_commands.post_fix_user_choices_excluded` (banned this transition) \u2014 always pick from `post_fix_user_choices` and never call `post-fix --user-choice` with a value that appears in `post_fix_user_choices_excluded`; non-ideal states returned as `success` with descriptive fields"
    },
    {
      "operation": "Validate review progress",
      "command": "`review/validate-review-progress.py --phase record\\|conventions\\|check\\|reset [args...]` \u2014 `record`: `--dimension KEY --read-file --checks-cited N`; `conventions`: `--summary \"...\"`; `check`: validates all dimensions complete; `reset`: clears state"
    },
    {
