{
  "schemaVersion": "1.0.0",
  "_doc": "Handoff registry — agent-facing literal next-action commands keyed by script_id (Phase 0 V-6). Populated incrementally per vertical; workspace entries land in Phase 1c. See sdd_core/handoffs.py for the loader contract; commands may use {ctx.<field>} placeholders bound at emission time against the WorkflowContext. Read-only audit shims and deprecated scripts intentionally omit handoffs.",
  "scripts": {
    "workspace/phase-approve.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --target {ctx.target} --phase launch",
          "note": "Open the next phase's review pipeline once approval lands."
        },
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Confirm tracker advanced to the next currentPhase."
        }
      ]
    },
    "workspace/check-spec-shape.py": {
      "handoffs": [
        {
          "id": "workspace/update-tracker",
          "command": ".spec-workflow/sdd workspace/update-tracker.py --workspace {ctx.workspace} --target {ctx.target_with_repo} --phase {ctx.phase} --doc-status reviewed",
          "note": "Mark the validated sub-spec doc as reviewed."
        },
        {
          "id": "workspace/phase-approve",
          "command": ".spec-workflow/sdd workspace/phase-approve.py --workspace {ctx.workspace} --target {ctx.target} --doc {ctx.phase}",
          "note": "Run phase-approve once every active repo reports reviewed."
        }
      ]
    },
    "workspace/update-tracker.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Verify the tracker write took effect."
        }
      ]
    },
    "workspace/advance-phase.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --target {ctx.target} --phase launch",
          "note": "Launch the review pipeline for the new currentPhase."
        },
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Confirm the phase advance landed in the tracker."
        }
      ]
    },
    "workspace/init.py": {
      "handoffs": [
        {
          "id": "workspace/init-feature",
          "command": ".spec-workflow/sdd workspace/init-feature.py --workspace {ctx.workspace} --target <feature> --repo coordinator:{ctx.workspace}:<sub-spec>",
          "note": "Bootstrap a workspace feature once the workspace is initialised."
        }
      ]
    },
    "workspace/init-feature.py": {
      "handoffs": [
        {
          "id": "workspace/update-manifest:set-repo-role",
          "command": ".spec-workflow/sdd workspace/update-manifest.py --workspace {ctx.workspace} --target {ctx.target} set-repo-role --repo-id <repo-id> --role \"<short repo-purpose description>\"",
          "note": "Populate the free-form role on each repo flagged with manifest-role-unset."
        },
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Confirm the feature bootstrap landed in the tracker."
        }
      ]
    },
    "workspace/update-manifest.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Verify the manifest write took effect."
        }
      ]
    },
    "workspace/check-health.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Read tracker state once the workspace is healthy."
        }
      ]
    },
    "workspace/ensure-healthy.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Read tracker state once pre-flight passes."
        }
      ]
    },
    "workspace/preflight-all.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Read coordination tracker state across the fan-out."
        }
      ]
    },
    "workspace/check-status.py": {
      "handoffs": [
        {
          "id": "workspace/phase-status",
          "command": ".spec-workflow/sdd workspace/phase-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Drill into per-repo docStatus for the current phase."
        }
      ]
    },
    "workspace/phase-status.py": {
      "handoffs": [
        {
          "id": "workspace/phase-approve",
          "command": ".spec-workflow/sdd workspace/phase-approve.py --workspace {ctx.workspace} --target {ctx.target} --doc {ctx.phase}",
          "note": "Approve the current doc once every repo reports reviewed."
        }
      ]
    },
    "workspace/extract-delegation.py": {
      "handoffs": [
        {
          "id": "workspace/check-spec-shape",
          "command": ".spec-workflow/sdd workspace/check-spec-shape.py --workspace {ctx.workspace} --target {ctx.target_with_repo}",
          "note": "Validate the sub-spec docs once authored from the delegation context."
        }
      ]
    },
    "workspace/reconcile-tracker.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Confirm the reconciled summary."
        }
      ]
    },
    "workspace/retroactive-review.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Verify retroactive stamps landed in the tracker."
        }
      ]
    },
    "workspace/set-doc-approval.py": {
      "handoffs": [
        {
          "id": "workspace/phase-approve",
          "command": ".spec-workflow/sdd workspace/phase-approve.py --workspace {ctx.workspace} --target {ctx.target} --doc {ctx.phase}",
          "note": "Advance the phase once every repo has approval recorded."
        }
      ]
    },
    "workspace/batch-approve.py": {
      "handoffs": [
        {
          "id": "workspace/confirm-batch-approval",
          "command": ".spec-workflow/sdd workspace/confirm-batch-approval.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "After user consents, confirm the batch presented above."
        }
      ]
    },
    "workspace/confirm-batch-approval.py": {
      "handoffs": [
        {
          "id": "workspace/check-status",
          "command": ".spec-workflow/sdd workspace/check-status.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Confirm the batch approval landed in the tracker."
        }
      ]
    },
    "workspace/resolve-advisory.py": {
      "handoffs": [
        {
          "id": "workspace/resolve-advisory:mark-resolved",
          "command": ".spec-workflow/sdd workspace/resolve-advisory.py --workspace {ctx.workspace} --name <advisory-name>",
          "note": "Mark a workspace advisory resolved for the current session."
        }
      ]
    },
    "review/pipeline-tick.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:post-review",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category {ctx.category} --target-name {ctx.target} --phase post-review",
          "note": "Run post-review once the sub-agent has written the review-quality artifact."
        },
        {
          "id": "review/pipeline-tick:discard",
          "emitter": "build_pipeline_tick_discard_command",
          "kwargs": {
            "gate_id": "{ctx.target}",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --phase discard -- --gate-id {ctx.target}",
          "note": "Discard a mid-flight gate session and reset for re-launch."
        },
        {
          "id": "review/pipeline-tick:update-launch",
          "emitter": "build_pipeline_tick_update_launch_command",
          "kwargs": {
            "category": "{ctx.category}",
            "target_name": "{ctx.target}",
            "doc_list": "{ctx.phase}",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category {ctx.category} --target-name {ctx.target} --phase update-launch --doc-list \"{ctx.phase}\" --workflow-mode update",
          "note": "Open update-mode launch for an existing multi-doc spec."
        },
        {
          "id": "review/pipeline-tick:print-field",
          "emitter": "build_pipeline_tick_print_field_command",
          "kwargs": {
            "field_path": "data.next_action_command",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd review/pipeline-tick.py --print-field data.next_action_command --workspace {ctx.workspace}",
          "note": "Extract a single envelope field for shell composition."
        }
      ]
    },
    "review/snapshot-and-mark-reviewed.py": {
      "handoffs": [
        {
          "id": "workspace/phase-approve",
          "command": ".spec-workflow/sdd workspace/phase-approve.py --workspace {ctx.workspace} --target {ctx.target} --doc {ctx.phase}",
          "note": "Approve the phase once every active repo reports reviewed."
        }
      ]
    },
    "review/validate-review-artifact.py": {
      "handoffs": [
        {
          "id": "workspace/phase-approve",
          "command": ".spec-workflow/sdd workspace/phase-approve.py --workspace {ctx.workspace} --target {ctx.target} --doc {ctx.phase}",
          "note": "Advance the phase once the artifact is valid and findings have been resolved."
        }
      ]
    },
    "review/check-re-review.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category {ctx.category} --target-name {ctx.target} --phase launch",
          "note": "Re-launch the review pipeline when the doc has changed since the last review."
        }
      ]
    },
    "spec/lint-requirements.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category spec --target-name {ctx.target} --phase launch --doc requirements",
          "note": "Run the review pipeline once the requirements lint passes."
        },
        {
          "id": "spec/check-traceability",
          "command": ".spec-workflow/sdd spec/check-traceability.py --target {ctx.target} --workspace {ctx.workspace}",
          "note": "Cross-check requirement IDs against tasks.md once requirements are clean."
        }
      ]
    },
    "spec/lint-design.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category spec --target-name {ctx.target} --phase launch --doc design",
          "note": "Run the review pipeline once the design lint passes."
        }
      ]
    },
    "spec/lint-tasks.py": {
      "handoffs": [
        {
          "id": "spec/check-traceability",
          "command": ".spec-workflow/sdd spec/check-traceability.py --target {ctx.target} --workspace {ctx.workspace}",
          "note": "Confirm every requirement in requirements.md has a covering task."
        },
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category spec --target-name {ctx.target} --phase launch --doc tasks",
          "note": "Run the review pipeline once tasks lint and traceability are clean."
        }
      ]
    },
    "spec/check-traceability.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category spec --target-name {ctx.target} --phase launch --doc tasks",
          "note": "Run the review pipeline once full coverage is reported."
        }
      ]
    },
    "spec/check-status.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "emitter": "build_review_pipeline_launch_command",
          "kwargs": {
            "target_name": "{ctx.target}",
            "category": "spec",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category spec --target-name {ctx.target} --phase launch",
          "note": "Open the review pipeline for the spec's current phase."
        },
        {
          "id": "spec/check-status:audit-log-aware",
          "command": ".spec-workflow/sdd spec/check-status.py --target {ctx.target} --workspace {ctx.workspace}",
          "note": "Phase-status check that consults approval-audit.log alongside snapshots."
        }
      ]
    },
    "spec/detect-context.py": {
      "handoffs": [
        {
          "id": "spec/check-status",
          "command": ".spec-workflow/sdd spec/check-status.py --target {ctx.target} --workspace {ctx.workspace}",
          "note": "Read the spec's current phase once the workflow context is known."
        }
      ]
    },
    "spec/detect-type.py": {
      "handoffs": [
        {
          "id": "spec/check-status",
          "command": ".spec-workflow/sdd spec/check-status.py --target {ctx.target} --workspace {ctx.workspace}",
          "note": "Surface the spec's current phase after classification."
        }
      ]
    },
    "spec/archive.py": {
      "handoffs": [
        {
          "id": "spec/check-status",
          "command": ".spec-workflow/sdd spec/check-status.py --all --workspace {ctx.workspace}",
          "note": "Confirm the archive transition by listing remaining active specs."
        }
      ]
    },
    "discovery/init-project.py": {
      "handoffs": [
        {
          "id": "discovery/validate-manifest",
          "command": ".spec-workflow/sdd discovery/validate-manifest.py --name {ctx.target} --workspace {ctx.workspace}",
          "note": "Validate the freshly-initialised manifest before adding artifacts."
        }
      ]
    },
    "discovery/update-manifest.py": {
      "handoffs": [
        {
          "id": "discovery/validate-manifest",
          "command": ".spec-workflow/sdd discovery/validate-manifest.py --name {ctx.target} --workspace {ctx.workspace}",
          "note": "Validate the manifest after each mutation lands."
        }
      ]
    },
    "discovery/validate-manifest.py": {
      "handoffs": [
        {
          "id": "discovery/update-manifest",
          "command": ".spec-workflow/sdd discovery/update-manifest.py --name {ctx.target} --workspace {ctx.workspace} set-project-status --status approved",
          "note": "Promote the project status once the manifest validates cleanly."
        }
      ]
    },
    "prd/validate-prd.py": {
      "handoffs": [
        {
          "id": "review/pipeline-tick:launch",
          "command": ".spec-workflow/sdd review/pipeline-tick.py --workspace {ctx.workspace} --category discovery --target-name {ctx.target} --phase launch --doc prd",
          "note": "Run the review pipeline once the PRD passes structural validation."
        }
      ]
    },
    "prd/validate-readiness.py": {
      "handoffs": [
        {
          "id": "prd/validate-prd",
          "command": ".spec-workflow/sdd prd/validate-prd.py .spec-workflow/discovery/{ctx.target}/prd.md",
          "note": "Run the structural PRD lint once the readiness gate passes."
        }
      ]
    },
    "prd/write-session-state.py": {
      "handoffs": [
        {
          "id": "prd/validate-readiness",
          "command": ".spec-workflow/sdd prd/validate-readiness.py --target {ctx.target} --gate pre-requirements --session-file --workspace {ctx.workspace}",
          "note": "Re-check the readiness gate after each session step lands."
        }
      ]
    },
    "approval/request.py": {
      "handoffs": [
        {
          "id": "approval/request:open-with-commands-suite",
          "command": ".spec-workflow/sdd approval/request.py --title \"<title>\" --file-paths \"<doc>.md\" --type document --category {ctx.category} --target-name {ctx.target}",
          "note": "Emit an approval request whose JSON includes the post-decision command suite."
        }
      ]
    },
    "review/update-quality.py": {
      "handoffs": [
        {
          "id": "review/update-quality:write-tier2",
          "emitter": "build_review_update_quality_command",
          "kwargs": {
            "target": "{ctx.target}",
            "category": "{ctx.category}",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd review/update-quality.py --workspace {ctx.workspace} --type {ctx.category} --target {ctx.target}",
          "note": "Refresh the canonical review-quality artifact with the latest tier-2 payload."
        }
      ]
    },
    "workspace/sync-skills-pack.py": {
      "handoffs": [
        {
          "id": "workspace/sync-skills-pack:rotate",
          "emitter": "build_sync_skills_pack_command",
          "kwargs": {
            "feature": "{ctx.target}",
            "workspace_path": "{ctx.workspace}"
          },
          "command": ".spec-workflow/sdd workspace/sync-skills-pack.py --workspace {ctx.workspace} --target {ctx.target}",
          "note": "Rotate workspace-shared reference docs from the coordinator to every target repo."
        }
      ]
    },
    "workspace/phase-history.py": {
      "_doc": "Read-only audit shim — surfaces the tracker's phaseHistory slice; no state mutation, so no canonical next-step handoff applies.",
      "handoffs": []
    },
    "review/pipeline-explain.py": {
      "_doc": "Internal pipeline plumbing — read-only debug surface for gate transitions; output is informational and has no canonical follow-up command.",
      "handoffs": []
    },
    "review/pipeline-manifest.py": {
      "_doc": "Internal pipeline plumbing — emits a static capability manifest at session init; no follow-up action applies.",
      "handoffs": []
    },
    "review/pipeline-run.py": {
      "_doc": "Internal pipeline plumbing — orchestrator that loops pipeline-tick.py until terminal; the per-tick envelope already carries next_action_command, so wrapping it again would duplicate routing.",
      "handoffs": []
    },
    "review/prepare-pipeline.py": {
      "_doc": "Internal pipeline plumbing — generates sub-agent prompts consumed by pipeline-tick.py; the dispatcher owns the next step, not this prep shim.",
      "handoffs": []
    }
  }
}
